{
   "action": {
      "default_icon": "images/nb_button_grey.gif",
      "default_popup": "./html/popup.html",
      "default_title": "Trellix Endpoint Security Web Control"
   },
   "background": {
      "service_worker": "mcafee_wa_bkground.js",
      "type": "module"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "sizzle.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "js": [ "punycode.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "js": [ "mcafee_wa_coreengine.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "js": [ "mcafee_wa_contentplg.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   } ],
   "content_security_policy": {
      "extension_pages": "default-src 'self'"
   },
   "default_locale": "en",
   "description": "Web Control",
   "host_permissions": [ "http://*/*", "https://*/*" ],
   "icons": {
      "128": "images/128.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Trellix Endpoint Security Web Control",
   "permissions": [ "webRequest", "tabs", "nativeMessaging", "downloads", "cookies", "storage" ],
   "update_url": "http://clients2.google.com/service/update2/crx",
   "version": "10.7.0.5779",
   "web_accessible_resources": [ {
      "matches": [ "http://*/*", "https://*/*" ],
      "resources": [ "html/*.html", "images/*.png", "images/*.gif", "json/*.json", "Resources/mcafee.gif" ]
   } ]
}
